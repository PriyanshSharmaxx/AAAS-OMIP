# Queue / Async Agent Execution — REST Client test file
@baseUrl = http://localhost:4000
@token = YOUR_JWT_TOKEN_HERE
@agentId = seed-agent-research-bot
# Replace after /run/async:
@jobId = JOB_ID_HERE
@executionId = EXECUTION_ID_HERE

### ── ASYNC RUN (enqueue and return immediately) ─────────────────────────────
# Returns 202 with { jobId, executionId, pollUrl }
POST {{baseUrl}}/api/agents/run/async
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "agentId": "{{agentId}}",
  "userInput": "What are the key differences between GPT-4o and Claude 3.5 Sonnet?",
  "triggerSource": "manual"
}

###

### ── ASYNC RUN (with overrides) ─────────────────────────────────────────────
POST {{baseUrl}}/api/agents/run/async
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "agentId": "{{agentId}}",
  "userInput": "Summarise recent advances in quantum error correction.",
  "overrides": {
    "temperature": 0.2,
    "maxTokens": 1024
  },
  "triggerSource": "api"
}

###

### ── POLL JOB STATUS ─────────────────────────────────────────────────────────
# state: "waiting" | "active" | "completed" | "failed" | "delayed"
# progress: 0-100
GET {{baseUrl}}/api/agents/jobs/{{jobId}}
Authorization: Bearer {{token}}

###

### ── QUEUE HEALTH STATS ───────────────────────────────────────────────────────
# Returns waiting/active/completed/failed counts for both queues
GET {{baseUrl}}/api/agents/queue/stats
Authorization: Bearer {{token}}

###

### ── GET COMPLETED EXECUTION (once job state = "completed") ─────────────────
GET {{baseUrl}}/api/agents/runs/{{executionId}}
Authorization: Bearer {{token}}

###

### ── SYNC RUN (existing — still works) ──────────────────────────────────────
POST {{baseUrl}}/api/agents/run
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "agentId": "{{agentId}}",
  "userInput": "Give me a 3-sentence overview of machine learning.",
  "triggerSource": "manual"
}

###

### ── LIST ALL MY RUNS (includes both sync and async) ────────────────────────
GET {{baseUrl}}/api/agents/runs?limit=10
Authorization: Bearer {{token}}

###

### ── TEST: poll non-existent job (should return 404) ────────────────────────
GET {{baseUrl}}/api/agents/jobs/non-existent-job-id-123
Authorization: Bearer {{token}}

###
